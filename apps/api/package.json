{
  "name": "@xivflips/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "market:snapshot": "tsx src/worker/market-snapshot.ts",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "~1.19.6",
    "@hono/zod-validator": "~0.7.6",
    "@xivflips/shared": "workspace:*",
    "dotenv": "~17.4.2",
    "drizzle-orm": "~0.45.1",
    "hono": "~4.11.1",
    "jose": "~6.1.3",
    "pg": "~8.21.0",
    "zod": "~4.4.3"
  },
  "devDependencies": {
    "@types/node": "~25.9.3",
    "@types/pg": "~8.20.0",
    "drizzle-kit": "~0.31.8",
    "tsx": "~4.22.4",
    "typescript": "~6.0.3",
    "vitest": "~4.1.8"
  }
}
